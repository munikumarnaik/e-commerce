{
  "info": {
    "name": "E-Commerce API",
    "description": "Complete API collection for the E-Commerce project (Food & Clothing)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000", "type": "string" },
    { "key": "version", "value": "v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/{{version}}/auth/register/", "host": ["{{baseUrl}}"], "path": ["api", "{{version}}", "auth", "register", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"johndoe\",\n  \"password\": \"StrongPass123!\",\n  \"password_confirm\": \"StrongPass123!\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"phone\": \"9876543210\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', jsonData.data.tokens.access);",
                  "  pm.collectionVariables.set('refreshToken', jsonData.data.tokens.refresh);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/{{version}}/auth/login/", "host": ["{{baseUrl}}"], "path": ["api", "{{version}}", "auth", "login", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', jsonData.data.tokens.access);",
                  "  pm.collectionVariables.set('refreshToken', jsonData.data.tokens.refresh);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/{{version}}/auth/logout/", "host": ["{{baseUrl}}"], "path": ["api", "{{version}}", "auth", "logout", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/{{version}}/auth/token/refresh/", "host": ["{{baseUrl}}"], "path": ["api", "{{version}}", "auth", "token", "refresh", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/{{version}}/auth/verify-email/", "host": ["{{baseUrl}}"], "path": ["api", "{{version}}", "auth", "verify-email", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"your-verification-token-here\"\n}"
            }
          }
        },
        {
          "name": "Password Reset Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/{{version}}/auth/password/reset/", "host": ["{{baseUrl}}"], "path": ["api", "{{version}}", "auth", "password", "reset", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            }
          }
        },
        {
          "name": "Password Reset Confirm",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/{{version}}/auth/password/reset/confirm/", "host": ["{{baseUrl}}"], "path": ["api", "{{version}}", "auth", "password", "reset", "confirm", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"your-reset-token-here\",\n  \"password\": \"NewStrongPass123!\",\n  \"password_confirm\": \"NewStrongPass123!\"\n}"
            }
          }
        }
      ]
    },
